# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# JWT
JWT_SECRET=generate-a-secure-random-string

# Server
PORT=7034
BASE_URL=http://localhost:7034

# Optional: restrict to specific emails (comma-separated)
# ALLOWED_EMAILS=user1@example.com,user2@example.com

# Optional: additional CORS origins (comma-separated)
# CORS_ORIGINS=https://your-domain.com

# Optional: additional Vite allowed hosts (comma-separated)
# VITE_ALLOWED_HOSTS=your-domain.com
