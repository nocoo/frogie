# L2 + G2: pre-push hook
# Target: <3min execution time

echo "🚀 Running pre-push checks..."

# G2: Security scan - check for vulnerabilities in dependencies
echo "🔒 Scanning dependencies for vulnerabilities..."
bunx osv-scanner --lockfile=bun.lock || echo "⚠️ OSV scanner warning (non-blocking for now)"

# G2: Check for secrets
echo "🔑 Checking for leaked secrets..."
bunx gitleaks detect --source . --verbose --no-git || echo "⚠️ Gitleaks warning (non-blocking for now)"

