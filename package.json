{
  "name": "frogie",
  "private": true,
  "version": "0.1.1",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run --parallel dev:server dev:web",
    "dev:server": "bun run --cwd packages/server dev",
    "dev:web": "bun run --cwd packages/web dev",
    "build": "bun run --parallel build:server build:web",
    "build:server": "bun run --cwd packages/server build",
    "build:web": "bun run --cwd packages/web build",
    "typecheck": "bun run typecheck:server && bun run typecheck:web",
    "typecheck:server": "node_modules/@typescript/native/bin/tsc --noEmit -p packages/server/tsconfig.json",
    "typecheck:web": "node_modules/@typescript/native/bin/tsc --noEmit -p packages/web/tsconfig.json",
    "lint": "eslint . --max-warnings 0",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:l2": "vitest run packages/server/src/routes/",
    "test:l3": "playwright test",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@types/bun": "^1.3.14",
    "@types/node": "^26.1.1",
    "@typescript/native": "npm:typescript@^7.0.2",
    "@vitest/coverage-v8": "^4.1.10",
    "bun-types": "^1.3.14",
    "eslint": "^10.7.0",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "jsdom": "^29.0.1",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.65.0",
    "vitest": "^4.1.10"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --max-warnings=0"
    ]
  },
  "overrides": {
    "@hono/node-server": "^2.0.5",
    "body-parser": ">=2.3.0",
    "brace-expansion": ">=5.0.7",
    "fast-uri": "^3.1.3",
    "hono": ">=4.12.31",
    "qs": ">=6.15.2",
    "undici": "^7.28.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "0.113.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "express-rate-limit": "^8.5.2",
    "hono": "^4.12.31",
    "ip-address": "^10.2.0"
  },
  "engines": {
    "node": ">=22"
  }
}
